source "https://rubygems.org"

# Matches the exact gem versions GitHub Pages runs in production, so a
# successful `bundle exec jekyll serve` locally mirrors what gets deployed.
gem "github-pages", group: :jekyll_plugins

# Tzinfo data for Windows / certain CI environments.
gem "tzinfo-data", platforms: [:mingw, :mswin, :x64_mingw, :jruby]

# Faster file watching on macOS during local development.
gem "wdm", "~> 0.1.1", platforms: [:mingw, :mswin, :x64_mingw]
